{
  "version": "2.0.0",
  "tasks": [
    {
      "type": "process",
      "label": "build",
      "command": "C:/msys64/usr/bin/bash.exe",
      "args": [
        "-lc",
        "export PATH=/mingw64/bin:/usr/bin:$PATH; cd \"$(cygpath -u \"${fileDirname}\")\" && g++ -std=c++23 -O2 -Wall \"${fileBasename}\" -o \"${fileBasenameNoExtension}.exe\""
      ],
      "options": {
        "cwd": "${fileDirname}"
      },
      "problemMatcher": ["$gcc"],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "type": "process",
      "label": "run (interactive)",
      "command": "C:/msys64/usr/bin/bash.exe",
      "args": [
        "-lc",
        "export PATH=/mingw64/bin:/usr/bin:$PATH; cd \"$(cygpath -u \"${fileDirname}\")\" && g++ -std=c++23 -O2 -Wall \"${fileBasename}\" -o \"${fileBasenameNoExtension}.exe\" && ./\"${fileBasenameNoExtension}.exe\""
      ],
      "options": {
        "cwd": "${fileDirname}"
      },
      "problemMatcher": ["$gcc"]
    },
    {
      "type": "process",
      "label": "run (input.txt)",
      "command": "C:/msys64/usr/bin/bash.exe",
      "args": [
        "-lc",
        "export PATH=/mingw64/bin:/usr/bin:$PATH; cd \"$(cygpath -u \"${fileDirname}\")\" && g++ -std=c++23 -O2 -Wall \"${fileBasename}\" -o \"${fileBasenameNoExtension}.exe\" && if [ -f input.txt ]; then ./\"${fileBasenameNoExtension}.exe\" < input.txt; else echo 'input.txt not found in this folder'; fi"
      ],
      "options": {
        "cwd": "${fileDirname}"
      },
      "problemMatcher": ["$gcc"]
    }
  ]
}
